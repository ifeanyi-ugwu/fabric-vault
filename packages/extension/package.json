{
  "name": "@fabric-vault/extension",
  "displayName": "FabricVault",
  "version": "0.0.3",
  "description": "A secure browser extension wallet for Hyperledger Fabric",
  "author": "ifeanyi ugwu <valentineifeanyiugwu@outlook.com>",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@fabric-vault/types": "workspace:*",
    "@noble/curves": "^1.9.0",
    "@plasmohq/messaging": "^0.7.1",
    "@tanstack/react-router": "^1.117.1",
    "@tanstack/router": "0.0.1-beta.53",
    "plasmo": "0.90.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*",
      "http://*/*",
      "ws://*/*",
      "wss://*/*"
    ],
    "permissions": [
      "storage",
      "activeTab"
    ]
  }
}
