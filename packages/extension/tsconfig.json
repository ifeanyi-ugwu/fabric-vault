{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": ["node_modules"],
  "include": [
    ".plasmo/index.d.ts",
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "compilerOptions": {
    "paths": {
      "~*": ["./src/*"],
      "@fabric-vault/types": ["../../packages/types/src/index.ts"]
    },
    "baseUrl": ".",
    "strictNullChecks": true
  }
}
